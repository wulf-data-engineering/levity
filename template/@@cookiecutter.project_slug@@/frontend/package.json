{
	"name": "frontend",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && node scripts/inject-splash-into-fallback.mjs",
		"preview": "vite preview",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"prepare": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide && svelte-kit sync || echo ''",
		"check": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide && svelte-kit sync && svelte-check --tsconfig tsconfig.json",
		"check:watch": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide && svelte-kit sync && svelte-check --tsconfig tsconfig.json --watch",
		"format": "prettier --write .",
		"check-format": "prettier --check .",
		"lint": "eslint .",
		"test:unit": "vitest run",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"gen:proto": "node scripts/generate-protobuf-files.mjs"
	},
	"supportedArchitectures": {
		"os": [
			"darwin",
			"linux"
		],
		"cpu": [
			"x64",
			"arm64"
		]
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^9.37.0",
		"@inlang/paraglide-js": "^2.20.2",
		"@inlang/paraglide-sveltekit": "^0.16.1",
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^1.21.0",
		"@playwright/test": "^1.60.0",
		"@storybook/addon-docs": "^10.4.6",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/sveltekit": "^10.4.6",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.68.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.10",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.4.2",
		"@types/node": "^25.9.3",
		"@types/snappyjs": "^0.7.1",
		"@vitest/browser": "^4.1.9",
		"axe-playwright": "^2.2.2",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"dotenv": "^17.4.2",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"jsdom": "^29.1.1",
		"mode-watcher": "^1.1.0",
		"playwright": "^1.61.1",
		"prettier": "3.8.4",
		"prettier-plugin-svelte": "4.1.1",
		"prettier-plugin-tailwindcss": "0.8.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"svelte-sonner": "^1.1.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.1.1",
		"tailwindcss": "^4.1.13",
		"ts-proto": "^2.11.8",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.0",
		"vite": "^8.1.0",
		"vitest": "^4.0.17",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"@aws-amplify/auth": "^6.20.0",
		"amazon-cognito-identity-js": "^6.3.18",
		"aws-amplify": "^6.18.0",
		"snappyjs": "^0.7.0"
	}
}
